# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# GitHub personal access token for repository discovery.
# Required for full Code Search (30 req/min, unlimited results).
# Without it: 10 results/query, 10 req/min (unauthenticated).
# Create at: https://github.com/settings/tokens (scopes: public_repo, read:org)
GITHUB_TOKEN=your_github_token_here

# LocalStack Pro authentication token.
# Required for Pro features (advanced services, persistence, etc.).
# Obtain at: https://app.localstack.cloud/workspace/auth-token
LOCALSTACK_AUTH_TOKEN=your_localstack_auth_token_here

# Pulumi stack passphrase for local state encryption.
# This is not a secret for CI — set to a fixed value like "localstack-scanner".
# Only needed when running Pulumi-based samples locally.
PULUMI_CONFIG_PASSPHRASE=localstack-scanner
